PORT=8040
NODE_ENV=development

# Upstash Redis
REDIS_URL=rediss://:your_password@your-endpoint.upstash.io:6380

# Africa's Talking
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox          # change to your username in production
AT_SENDER_ID=TRYBE           # shortcode or alphanumeric sender

# Django backend
DJANGO_API_URL=
DJANGO_API_SECRET=
# Squad
SQUAD_WEBHOOK_SECRET=your_squad_webhook_secret_hash
SQUAD_PUBLIC_KEY=your_squad_public_key
SQUAD_SECRET_KEY=your_squad_secret_key
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com   # switch to live for prod

# OTP
OTP_TTL_SECONDS=300          # 5 minutes
OTP_LENGTH=6

# Twilio / WhatsApp
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

ANTHROPIC_API_KEY=

WEBHOOK_SECRET=make_this_a_long_random_string
